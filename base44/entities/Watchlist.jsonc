{
  "name": "Watchlist",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "User ID of the person watching"
    },
    "marketplace_item_id": {
      "type": "string",
      "description": "Reference to the MarketplaceItem"
    },
    "notification_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether to send alerts for this item"
    }
  },
  "required": [
    "user_id",
    "marketplace_item_id"
  ]
}